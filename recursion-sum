class Solution{	
	public:
		int NnumbersSum(int N){
			int sum=0;
            for(int i=1;i<=N;i++) {
                sum+=i;
            }
            return sum;
		}
};

class Solution{	
	public:
		int NnumbersSum(int N){
			int sum = (N * (N + 1)) / 2;
            return sum;
		}
};

class Solution:
public:
int NumbersSum(int N) {
if(N==1) return;
return N + NumbersSum(N-1);
}

